{
  "name": "busyq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-8081}",
    "lint": "next lint",
    "deploy": "npm run build && npm run start",
    "deploy:build": "npm run build",
    "deploy:start": "nohup npx next start -p ${PORT:-8081} > /var/log/busyq.log 2>&1 &",
    "deploy:stop": "lsof -ti :${PORT:-8081} | xargs kill -9 2>/dev/null; echo 'stopped'",
    "deploy:restart": "npm run deploy:stop && sleep 1 && npm run deploy:start"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "leaflet": "^1.9.4",

    "react-leaflet": "^4.2.1",
    "@types/leaflet": "^1.9.0",
    "lucide-react": "^0.300.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "class-variance-authority": "^0.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.4.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0"
  }
}
